# ─── WordPress Backend ────────────────────────────────────────────────────────
# Leave both unset to run in mock-data mode (no WP install needed).
# Set both to connect to a real WordPress site.
#
# WORDPRESS_URL=https://your-wp-site.com
# WORDPRESS_API_TOKEN=your-secret-bearer-token

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Password accepted by POST /api/auth/login (any username).
DEMO_MEMBER_PASSWORD=members-only-2026
